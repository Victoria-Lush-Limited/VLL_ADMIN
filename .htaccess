<IfModule mod_rewrite.c>
    Options +FollowSymLinks -Indexes
    RewriteEngine On

    # Subfolder URL ends here: send dashboard root to Laravel
    RewriteRule ^$ public/index.php [L]

    # Original flat PHP app (reference / fallback)
    RewriteRule ^legacy(/.*)?$ - [L]

    # Real files in project root (composer.json, etc.)
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^ - [L]

    # All other routes go through Laravel public/
    RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
